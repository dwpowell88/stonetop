{{!--
	Single-slot rich field: enriched display + a raw-markdown editor revealed by the pencil.
	Params: field (a RichText — rendered for display, .raw for the editor), inputClass, inputId,
	slug, placeholder, multiline.
--}}
<span class="stonetop-editable">
	<span class="stonetop-editable__display">{{rich field}}</span>
	{{#if multiline}}
	<textarea class="stonetop-editable__edit {{inputClass}}"{{#if inputId}} id="{{inputId}}"{{/if}} data-slug="{{slug}}" placeholder="{{placeholder}}">{{field.raw}}</textarea>
	{{else}}
	<input class="stonetop-editable__edit {{inputClass}}"{{#if inputId}} id="{{inputId}}"{{/if}} type="text" value="{{field.raw}}" data-slug="{{slug}}" placeholder="{{placeholder}}">
	{{/if}}
	<button type="button" class="stonetop-edit-toggle" title="Edit">
		<img src="systems/stonetop/assets/ui/controls/edit-icon.png" alt="edit">
	</button>
</span>
