<div class="stonetop-follower-card" data-slug="{{slug}}">

	{{#if showDelete}}
	<button type="button" class="stonetop-follower-delete" data-slug="{{slug}}" data-name="{{name}}"
	        title="{{localize 'stonetop.followers.remove'}} — {{localize 'stonetop.confirm.deleteHint'}}">
		<img src="systems/stonetop/assets/ui/controls/delete-icon.png" alt="{{localize 'stonetop.followers.remove'}}">
	</button>
	{{/if}}

	<div class="stonetop-follower-head">
		{{#if img}}<img class="stonetop-follower-img" src="{{img}}" alt="{{name}}">{{/if}}
		<div class="stonetop-follower-head-main">
			<input type="text" class="stonetop-follower-name-input" value="{{name}}" data-slug="{{slug}}">
			{{#if isCompanion}}
			<div class="stonetop-companion">
				<div class="stonetop-creature-line">
					<span class="stonetop-follower-label">{{localize "stonetop.followers.companionType"}}</span>
					{{> "stonetop.selection-input" sel=companionTypeSelection slug=slug field="companionType" inputClass="stonetop-companion-type" placeholder=(localize "stonetop.followers.companionType")}}
				</div>
				<div class="stonetop-companion-options">
					<span class="stonetop-follower-label">{{#if companionPickCount}}Pick {{companionPickCount}} more{{#if companionStartOptions.length}} <span class="stonetop-companion-pick">(start with {{#each companionStartOptions}}{{rich this}}{{#unless @last}}, {{/unless}}{{/each}})</span>{{/if}}{{else}}{{localize "stonetop.followers.companionOptions"}}{{/if}}</span>
					{{> "stonetop.selection-chips" sel=companionOptionsSelection slug=slug field="companionOptions" placeholder=(localize "stonetop.followers.addOption")}}
				</div>
			</div>
			{{else}}
			{{> "stonetop.selection-chips" sel=tagSelection slug=slug field="tagList" placeholder=(localize "stonetop.followers.notePlaceholder")}}
			{{/if}}
		</div>
	</div>

	<div class="stonetop-creature-statrow">
		<div class="stonetop-creature-statrow__fields">
			<div class="stonetop-creature-line">
				<span class="stonetop-follower-label">{{localize "stonetop.followers.armor"}}</span>
				{{> "stonetop.editable-field" field=armor slug=slug
					inputClass="stonetop-follower-armor"}}
			</div>
			<div class="stonetop-creature-line">
				<span class="stonetop-follower-label">{{localize "stonetop.followers.damage"}}</span>
				{{> "stonetop.editable-field" field=damage slug=slug
					inputClass="stonetop-follower-damage"}}
			</div>
			<div class="stonetop-creature-line">
				<span class="stonetop-follower-label">{{localize "stonetop.followers.instinct"}}</span>
				{{> "stonetop.selection-input" sel=instinctSelection slug=slug field="instinct" inputClass="stonetop-follower-instinct" placeholder=(localize "stonetop.followers.instinct")}}
			</div>
		</div>
		{{#unless isGroup}}
		<div class="stonetop-creature-hp">
			<span class="stonetop-follower-label">{{localize "stonetop.followers.hp"}}</span>
			<div class="stonetop-creature-hp__row">
				<input class="stonetop-creature-hp__input stonetop-follower-hp stonetop-step"
				       type="number" min="0" value="{{hp}}" data-slug="{{slug}}">
				<span>/</span>
				<input class="stonetop-creature-hp__input stonetop-follower-hp-max stonetop-step"
				       type="number" min="0" value="{{hpMax}}" data-slug="{{slug}}">
			</div>
		</div>
		{{/unless}}
	</div>

	<div class="stonetop-creature-line">
		<span class="stonetop-follower-label">{{localize "stonetop.followers.specialQuality"}}</span>
		{{> "stonetop.editable-field" field=specialQuality slug=slug inputClass="stonetop-follower-special-quality"}}
	</div>

	{{#if isGroup}}
	<div class="stonetop-members">
		<div class="stonetop-members-head">
			<span class="stonetop-follower-label">{{localize "stonetop.followers.members"}}</span>
			<button type="button" class="stonetop-member-add" data-slug="{{slug}}"
			        title="{{localize 'stonetop.followers.addMember'}}">
				<img src="systems/stonetop/assets/ui/controls/plus-icon.png" alt="{{localize 'stonetop.followers.addMember'}}">
			</button>
		</div>
		{{#if (hasText membersNote)}}<p class="stonetop-member-note">{{rich membersNote}}</p>{{/if}}
		{{#each members}}
		<div class="stonetop-member" data-slug="{{../slug}}" data-index="{{index}}">
			<div class="stonetop-member-top">
				<input type="text" class="stonetop-member-name" value="{{name}}"
				       data-slug="{{../slug}}" data-index="{{index}}"
				       placeholder="{{localize 'stonetop.followers.memberName'}}">
				<span class="stonetop-member-hp">
					<span class="stonetop-follower-label">{{localize "stonetop.followers.hp"}}</span>
					<input type="number" min="0" class="stonetop-member-hp-value stonetop-step"
					       value="{{hp.value}}" data-slug="{{../slug}}" data-index="{{index}}">
					<span>/</span>
					<input type="number" min="0" class="stonetop-member-hp-max stonetop-step"
					       value="{{hp.max}}" data-slug="{{../slug}}" data-index="{{index}}">
				</span>
				<button type="button" class="stonetop-member-remove" data-slug="{{../slug}}" data-index="{{index}}"
				        title="{{localize 'stonetop.followers.removeMember'}}">
					<img src="systems/stonetop/assets/ui/controls/delete-icon.png" alt="{{localize 'stonetop.followers.removeMember'}}">
				</button>
			</div>
			<div class="stonetop-member-row">
				<span class="stonetop-member-fieldlabel">{{localize "stonetop.followers.tags"}}</span>
				{{> "stonetop.selection-chips" sel=tagSelection slug=../slug field="tags"
					member=true memberIndex=index placeholder=(localize "stonetop.followers.addTag")}}
			</div>
			<div class="stonetop-member-row">
				<span class="stonetop-member-fieldlabel">{{localize "stonetop.followers.traits"}}</span>
				{{> "stonetop.selection-chips" sel=traitSelection slug=../slug field="traits"
					member=true memberIndex=index placeholder=(localize "stonetop.followers.addTrait")}}
			</div>
		</div>
		{{/each}}
		{{#if memberSuggestions.names.length}}
		<p class="stonetop-member-suggest"><strong>{{localize "stonetop.followers.suggestedNames"}}:</strong>
			{{#each memberSuggestions.names}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</p>
		{{/if}}
	</div>
	{{/if}}

	{{> "stonetop.editable-rich-block" label=(localize "stonetop.followers.moves")
		field=moves textareaClass="stonetop-follower-moves" slug=slug}}

	<div class="stonetop-creature-line stonetop-creature-line--split">
		<span class="stonetop-follower-label">{{localize "stonetop.followers.cost"}}</span>
		{{> "stonetop.selection-input" sel=costSelection slug=slug field="cost" inputClass="stonetop-follower-cost" placeholder=(localize "stonetop.followers.cost")}}
		<div class="stonetop-follower-loyalty">
			<span class="stonetop-follower-label">{{localize "stonetop.followers.loyalty"}}</span>
			{{> "stonetop.resource-track" resource=loyalty btnClass="stonetop-follower-loyalty-btn" slug=slug}}
		</div>
	</div>

	{{#if choices.list.length}}
	<div class="stonetop-follower-choices">
		{{#each choices.list}}
		{{> "stonetop.choice-row" cgContext="follower" cgGroup=../slug namePrefix=../slug}}
		{{/each}}
	</div>
	{{/if}}

	{{> "stonetop.follower-inventory"}}

	{{> "stonetop.editable-rich-block" label=(localize "stonetop.followers.description")
		field=description textareaClass="stonetop-follower-description" slug=slug}}

	{{> "stonetop.editable-rich-block" label=(localize "stonetop.followers.notes")
		field=notes textareaClass="stonetop-follower-notes" slug=slug blockClass="stonetop-follower-notes-block"}}

</div>
