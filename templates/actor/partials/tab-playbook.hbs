<div class="tab playbook" data-group="primary" data-tab="playbook">
	<section class="sheet-tab">

	{{#unless stonetop.playbook}}
	<div class="stonetop-playbook-empty">
		<p class="stonetop-playbook-empty-hint">{{localize "stonetop.sheet.playbook.emptyHint"}}</p>
		<select class="stonetop-playbook-select" name="stonetop-playbook-select">
			<option value="">— {{localize "stonetop.sheet.playbook.selectPlaceholder"}} —</option>
			{{#each availablePlaybooks}}
			<option value="{{slug}}">{{name}}</option>
			{{/each}}
		</select>
	</div>
	{{else}}
	<div class="stonetop-playbook-columns">

		{{> "stonetop.choice-section" groups=stonetop.playbook.loreGroups cgContext="lore"}}

		{{#if stonetop.playbook.background.options.length}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.background.label") note=(localize "stonetop.character.selection.chooseOne")}}
			{{#each stonetop.playbook.background.options}}
			<label class="stonetop-item{{#if selected}} is-checked{{/if}}">
				<div class="stonetop-item-header">
					<input type="radio" class="stonetop-item-check" name="stonetop-background" value="{{slug}}"{{#if selected}} checked{{/if}}>
					<strong class="stonetop-item-name">{{label}}</strong>
					{{#if resource}}
					<span class="stonetop-item-resources">
						{{> "stonetop.resource-track" resource=resource btnClass="stonetop-background-resource-btn" slug=slug}}
					</span>
					{{/if}}
				</div>
				{{#if description}}
				<div class="stonetop-item-description">{{{description}}}</div>
				{{/if}}
				{{#if choices}}
				<div class="stonetop-bg-choices">
					{{#each choices.list}}
					{{> "stonetop.choice-row" cgContext="background" cgGroup=../choices.slug namePrefix=../slug}}
					{{/each}}
				</div>
				{{/if}}
			</label>
			{{/each}}
		</div>
		{{/if}}

		{{#if stonetop.playbook}}
		{{> "stonetop.instinct-section"
		    instinctSelected=stonetop.playbook.instinctSelected
		    instinctGroup=stonetop.playbook.instinctGroup
		    namePrefix="stonetop-instinct"
		    cgContext="instinct"}}
		{{/if}}

		{{#if stonetop.playbook.appearanceGroup}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.appearance.label") note=(localize "stonetop.character.selection.appearance.instruction")}}
			{{#with stonetop.playbook.appearanceGroup}}
			{{> "stonetop.choice-group" cgContext="appearance"}}
			{{/with}}
		</div>
		{{/if}}

		{{#if stonetop.playbook.origin.options.length}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.origin.label") note=(localize "stonetop.character.selection.origin.instruction")}}
			{{#each stonetop.playbook.origin.options}}
			<div class="stonetop-origin-option{{#if selected}} selected{{/if}}">
				<label class="stonetop-origin-region">
					<input type="radio" class="stonetop-item-check" name="stonetop-origin"
					       value="{{region}}"{{#if selected}} checked{{/if}}>
					<strong>{{region}}</strong>
				</label>
				<div class="stonetop-origin-names">
					{{#each names}}<span class="stonetop-origin-name">{{this}}</span>{{#unless @last}}, {{/unless}}{{/each}}
				</div>
			</div>
			{{/each}}
		</div>
		{{/if}}

	</div>

	{{#if stonetop.playbook.introductions}}
	<div class="stonetop-panel-divider" aria-hidden="true"></div>
	{{> "stonetop.introductions-section" intro=stonetop.playbook.introductions}}
	{{/if}}
	{{/unless}}

	</section>
</div>
