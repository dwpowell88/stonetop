{{!-- A multi-select Selection as removable pills + an inline-expanding combobox to add one. Type
      a custom tag in the input, or hit ▾ to drop the FULL unselected-option list (never filtered).
      The list opens in normal flow so it can't be clipped by the card's stacking contexts. Picking
      an option (or pressing Enter on a typed value) feeds the .stonetop-tag-add input and fires its
      change; the sheet's chip/add handlers toggle the value.
      Params: sel (Selection snapshot), slug, field, placeholder, member (bool), memberIndex. --}}
<div class="stonetop-tags" data-slug="{{slug}}" data-field="{{field}}"{{#if member}} data-member-index="{{memberIndex}}"{{/if}}>
	{{#each sel.values}}
	<button type="button" class="stonetop-tag-chip is-selected" data-slug="{{../slug}}" data-tag="{{this}}"
	        title="{{#if (eq this "group")}}{{localize 'stonetop.followers.groupTagTooltip'}}{{else}}{{localize 'stonetop.followers.remove'}}{{/if}}">{{{md this}}}</button>
	{{/each}}
	<span class="stonetop-combo stonetop-combo--add">
		<input type="text" class="stonetop-tag-add stonetop-combo-input"
		       data-slug="{{slug}}" data-field="{{field}}" placeholder="{{placeholder}}">
		{{#if sel.unselectedOptions.length}}
		<button type="button" class="stonetop-combo-toggle" tabindex="-1" aria-label="{{placeholder}}">▾</button>
		<ul class="stonetop-combo-list" hidden>
			{{#each sel.unselectedOptions}}<li class="stonetop-combo-option" data-value="{{this}}"{{#if (eq this "group")}} title="{{localize 'stonetop.followers.groupTagTooltip'}}"{{/if}}>{{{md this}}}</li>{{/each}}
		</ul>
		{{/if}}
	</span>
</div>
