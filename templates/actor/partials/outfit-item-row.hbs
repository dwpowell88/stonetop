{{!-- One outfit-item row (shared by the inventory tab, follower inventory, and arcanum cards).
      Context = an OutfitItemSnapshot-like { slug, name, weight, tags, note, checked, resource,
      isCustom, ownedId }. The weight diamonds + resource toggle the character's inventory keyed by
      `slug`. --}}
<div class="stonetop-inv-item{{#if checked}} is-checked{{/if}}">
	<span class="stonetop-inv-diamonds">
		{{#each (times weight)}}
		<input type="checkbox" class="stonetop-inventory-item-check stonetop-inv-diamond"
		       data-slug="{{../slug}}" {{#if ../checked}}checked{{/if}}>
		{{/each}}
	</span>
	<span class="stonetop-inv-label">{{name}}
		{{#if tags.raw}}<span class="stonetop-inv-tags">{{rich tags}}</span>{{/if}}
		{{#if note.raw}}<span class="stonetop-inv-note">({{rich note}})</span>{{/if}}
	</span>
	{{#if resource}}
	<span class="stonetop-inv-resources">
		{{> "stonetop.resource-track" resource=resource btnClass="stonetop-inv-resource-btn stonetop-inventory-resource-btn" slug=slug}}
	</span>
	{{/if}}
	{{#if isCustom}}
	<a class="stonetop-inv-delete" data-owned-id="{{ownedId}}" title="{{localize 'stonetop.inventory.removeItem'}}"><i class="fas fa-times"></i></a>
	{{/if}}
</div>
