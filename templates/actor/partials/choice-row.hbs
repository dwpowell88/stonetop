{{#*inline "follower-check"}}
<input type="checkbox" class="stonetop-arcanum-follower-check"
       data-change-action="followerCheck"
       data-cg-context="{{cgContext}}"
       data-slug="{{cgGroup}}"
       data-option="{{slug}}"
       data-index="0"
       {{#if (lookup track.checks 0)}}checked{{/if}}>
{{/inline}}
{{#*inline "track-checks"}}
{{#each track.checks}}
<input type="checkbox"
    class="stonetop-cg-track"
    data-change-action="cgTrack"
    data-cg-context="{{../cgContext}}"
    data-cg-group="{{../cgGroup}}"
    data-cg-option="{{../track.slug}}"
    data-cg-index="{{@index}}"
    {{#if this}}checked{{/if}}>
{{/each}}
{{/inline}}
{{! Row-level fields come via `row=..` (an inline partial resets the `../` chain, so they
    cannot be reached with `../`); the option comes via `opt=this`. }}
{{#*inline "pick-input"}}
<input type="{{#if row.radio}}radio{{else}}checkbox{{/if}}"
       class="stonetop-item-check{{#if row.cgContext}} stonetop-cg-pick{{/if}}{{#unless row.cgContext}} {{row.inputClass}}{{/unless}}"
       {{#if row.radio}}name="{{row.namePrefix}}-{{row.rowKey}}"{{/if}}
       {{#if row.cgContext}}
       data-change-action="cgPick"
       data-cg-context="{{row.cgContext}}"
       data-cg-group="{{row.cgGroup}}"
       data-cg-option="{{opt.slug}}"
       data-cg-siblings="{{row.siblingSlugsCsv}}"
       data-display-label="{{opt.text}}{{#if withDescription}} — {{opt.description.raw}}{{/if}}"
       {{else}}
       {{#if row.changeAction}}data-change-action="{{row.changeAction}}"{{/if}}
       {{#if row.possessionSlug}}data-possession-slug="{{row.possessionSlug}}"{{/if}}
       {{#if row.siblingSlugsCsv}}data-sibling-slugs-csv="{{row.siblingSlugsCsv}}"{{/if}}
       data-row-key="{{row.rowKey}}"
       data-choice-slug="{{opt.slug}}"
       {{/if}}
       {{#if opt.checked}}checked{{/if}}>
{{/inline}}
{{#if (eq type "entry")}}
{{! Entry row }}
{{#if followers}}
{{! Entry with followers }}
<div class="stonetop-arcanum-follower">
    {{#if inlineDisplay}}
    {{#if track}}
    {{> follower-check}}
    {{/if}}
    {{#each followers}}{{> "stonetop.follower-card" this}}{{/each}}
    {{else if (hasText content.text)}}
    <label class="stonetop-arcanum-follower-label">
        {{#if track}}
        {{> follower-check}}
        {{/if}}
        <span>{{rich content.text}}</span>
    </label>
    {{/if}}
</div>
{{else}}
{{! Entry without followers: content/track/input }}
{{#if (hasText content.title)}}{{> "stonetop.section-heading" title=content.title note=content.titleNote}}{{/if}}
{{#if track}}
{{#if (hasText content.subtitle)}}
<div class="stonetop-choice-track stonetop-column">
    <div class="stonetop-choice-header-wrapper">
        <span class="stonetop-choice-track-checks">
            {{> track-checks}}
        </span>
        {{> "stonetop.section-sub-heading" subtitle=content.subtitle subtitleNote=content.subtitleNote}}
    </div>
    <span class="stonetop-choice-track-desc">{{rich content.text}}</span>
</div>
{{else}}
<div class="stonetop-choice-track stonetop-row">
    <div class="stonetop-choice-track-checks">
        {{> track-checks}}
    </div>
    <span class="stonetop-choice-track-desc stonetop-choice-track-desc-row">{{rich content.text}}</span>
</div>
{{/if}}

{{else}}
{{! No track: still render the entry's subtitle/subtitleNote (the track branch above is the only
    other place they're emitted), then the body text. }}
{{#if (hasText content.subtitle)}}
{{> "stonetop.section-sub-heading" subtitle=content.subtitle subtitleNote=content.subtitleNote}}
{{/if}}
{{#if (hasText content.text)}}
<div class="stonetop-choice-description">{{rich content.text}}</div>
{{/if}}
{{/if}}
{{#if input}}
<div class="stonetop-choice-option stonetop-choice-option--text">
    {{#if cgContext}}
    {{! Always-visible data-entry box. input.type "rich" → multiline; "inline" → single-line. }}
    {{#if (eq input.type "rich")}}
    <textarea class="stonetop-cg-text stonetop-choice-input stonetop-choice-input--rich"
              data-change-action="cgText"
              data-cg-context="{{cgContext}}"
              data-cg-group="{{cgGroup}}"
              data-cg-option="{{input.slug}}"
              {{#if input.placeholder}}placeholder="{{input.placeholder}}"{{/if}}>{{input.value}}</textarea>
    {{else}}
    <input type="text" class="stonetop-cg-text stonetop-choice-input"
           data-change-action="cgText"
           data-cg-context="{{cgContext}}"
           data-cg-group="{{cgGroup}}"
           data-cg-option="{{input.slug}}"
           value="{{input.value}}"
           {{#if input.placeholder}}placeholder="{{input.placeholder}}"{{/if}}>
    {{/if}}
    {{else}}
    {{! Read-only preview (e.g. the move item sheet): just show the value. }}
    <span class="stonetop-choice-input-preview">{{#if input.value}}{{input.value}}{{else}}<span class="stonetop-editable__placeholder">{{input.placeholder}}</span>{{/if}}</span>
    {{/if}}
</div>
{{/if}}
{{/if}}
{{else}}
{{! Pick row (type="choice") }}
<div class="stonetop-choice-row{{#if inline}} stonetop-choice-row--inline{{/if}}">
    {{#each options}}
    {{#if (hasText description)}}
    {{! Pick mode — card layout when option has a description }}
    <label class="stonetop-item{{#if checked}} is-checked{{/if}}">
        <div class="stonetop-item-header">
            {{> pick-input row=.. opt=this withDescription=true}}
            <strong class="stonetop-item-name">{{text}}</strong>
        </div>
        <div class="stonetop-item-description">{{rich description}}</div>
    </label>
    {{else}}
    {{! Pick mode — inline (no description) }}
    <label class="stonetop-choice-option-label{{#if checked}} is-checked{{/if}}">
        {{> pick-input row=.. opt=this}}
        {{#if (eq type "input")}}
        <input type="text"
               class="stonetop-cg-text"
               data-change-action="cgText"
               data-cg-context="{{../cgContext}}"
               data-cg-group="{{../cgGroup}}"
               data-cg-option="{{slug}}-fill"
               value="{{fillValue}}">
        {{else}}
        {{text}}
        {{/if}}
    </label>
    {{/if}}
    {{/each}}
</div>
{{/if}}
