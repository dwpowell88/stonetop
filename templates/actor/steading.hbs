{{!-- V2 part: single root element; the sheet root form + classes come from DEFAULT_OPTIONS. --}}
<div>

	<header class="sheet-header steading-top">
		<div class="steading-steadfast-row">
			{{!-- Name combobox: type the steading's own name, or pick a steadfast from the list (which
			      seeds its profile and adopts its name). Dropping a steadfast onto the sheet does the same. --}}
			<span class="stonetop-combo steading-steadfast-combo">
				<input type="text" class="steading-steadfast-input stonetop-combo-input" value="{{actor.name}}"
				       placeholder="{{localize 'stonetop.steadfast.namePlaceholder'}}" {{#unless editable}}disabled{{/unless}}>
				{{#if availableSteadfasts.length}}
				<button type="button" class="stonetop-combo-toggle" tabindex="-1" aria-label="Steadfasts">▾</button>
				<ul class="stonetop-combo-list" hidden>
					{{#each availableSteadfasts}}<li class="stonetop-combo-option" data-value="{{name}}">{{name}}</li>{{/each}}
				</ul>
				{{/if}}
			</span>
			<span class="steading-steadfast-hint">Type a name, or pick / drag a steadfast.</span>
		</div>
		<section class="steading-header-grid">

			{{!-- Fortunes --}}
			<div class="steading-stat-panel steading-panel-frame steading-fortunes">
				<span class="panel-corner panel-corner-tl"></span>
				<span class="panel-corner panel-corner-tr"></span>
				<span class="panel-corner panel-corner-bl"></span>
				<span class="panel-corner panel-corner-br"></span>
				<span class="panel-edge panel-edge-top"></span>
				<span class="panel-edge panel-edge-right"></span>
				<span class="panel-edge panel-edge-bottom"></span>
				<span class="panel-edge panel-edge-left"></span>
				<h2>
					<button class="steading-stat-roll rollable" type="button" data-roll="fortunes">Fortunes</button>
				</h2>
				{{#if (hasText stonetop.fortunes.note)}}<div class="steading-start-line">{{rich stonetop.fortunes.note}}</div>{{/if}}
				<div class="steading-rating-options">
					{{#each stonetop.fortunes.options}}
						<label class="steading-rating-option">
							<input class="steading-box-input" type="radio" name="stonetop-fortunes" value="{{value}}" {{#if selected}}checked{{/if}}>
							<span class="steading-box" aria-hidden="true"></span>
							<span class="steading-option-text"><span>{{rich label}}</span></span>
						</label>
					{{/each}}
				</div>
			</div>

			{{!-- Surplus --}}
			<div class="steading-stat-panel steading-panel-frame steading-surplus">
				<span class="panel-corner panel-corner-tl"></span>
				<span class="panel-corner panel-corner-tr"></span>
				<span class="panel-corner panel-corner-bl"></span>
				<span class="panel-corner panel-corner-br"></span>
				<span class="panel-edge panel-edge-top"></span>
				<span class="panel-edge panel-edge-right"></span>
				<span class="panel-edge panel-edge-bottom"></span>
				<span class="panel-edge panel-edge-left"></span>
				<h2>
					<button class="steading-stat-roll rollable" type="button" data-roll="surplus">Surplus</button>
				</h2>
				{{#if (hasText stonetop.surplus.note)}}<div class="steading-start-line">{{rich stonetop.surplus.note}}</div>{{/if}}
				<input class="steading-surplus-input stonetop-step" type="number" value="{{stonetop.surplus.current}}" min="0" step="1">
			</div>

			{{!-- Size --}}
			{{> "stonetop.steading-stat-panel" attr="size" title="Size" attrData=stonetop.attributes.size panelClass="steading-size"}}

			{{!-- Population --}}
			{{> "stonetop.steading-stat-panel" attr="population" title="Population" attrData=stonetop.attributes.population rollable=true panelClass="steading-population"}}

			{{!-- Prosperity --}}
			{{> "stonetop.steading-stat-panel" attr="prosperity" title="Prosperity" attrData=stonetop.attributes.prosperity rollable=true panelClass="steading-prosperity"}}

			{{!-- Defenses --}}
			{{> "stonetop.steading-stat-panel" attr="defenses" title="Defenses" attrData=stonetop.attributes.defenses rollable=true wide=true panelClass="steading-defenses"}}

			{{!-- Debilities --}}
			<div class="steading-debilities-panel steading-panel-frame">
				<span class="panel-corner panel-corner-tl"></span>
				<span class="panel-corner panel-corner-tr"></span>
				<span class="panel-corner panel-corner-bl"></span>
				<span class="panel-corner panel-corner-br"></span>
				<span class="panel-edge panel-edge-top"></span>
				<span class="panel-edge panel-edge-right"></span>
				<span class="panel-edge panel-edge-bottom"></span>
				<span class="panel-edge panel-edge-left"></span>
				<h2>Debilities</h2>
				<div class="steading-debility-list">
					{{#each stonetop.debilities}}
						<label class="steading-debility-option">
							<input class="steading-circle-input" type="checkbox" data-slug="{{slug}}" {{#if active}}checked{{/if}}>
							<span class="steading-circle" aria-hidden="true"></span>
							<span>{{rich description}} <small>{{rich note}}</small></span>
						</label>
					{{/each}}
				</div>
			</div>

			{{!-- Roll Mode --}}
			<div class="steading-stat-panel steading-panel-frame steading-roll-mode">
				<span class="panel-corner panel-corner-tl"></span>
				<span class="panel-corner panel-corner-tr"></span>
				<span class="panel-corner panel-corner-bl"></span>
				<span class="panel-corner panel-corner-br"></span>
				<span class="panel-edge panel-edge-top"></span>
				<span class="panel-edge panel-edge-right"></span>
				<span class="panel-edge panel-edge-bottom"></span>
				<span class="panel-edge panel-edge-left"></span>
				<h2>{{localize "stonetop.rollMode.label"}}</h2>
				<div class="steading-rating-options">
					<label class="steading-rating-option">
						<input class="steading-box-input steading-roll-mode-radio" type="radio" name="stonetop-roll-mode" value="normal" {{#if (eq stonetop.rollMode "normal")}}checked{{/if}}>
						<span class="steading-box" aria-hidden="true"></span>
						<span class="steading-option-text"><span>{{localize "stonetop.rollMode.normal"}}</span></span>
					</label>
					<label class="steading-rating-option">
						<input class="steading-box-input steading-roll-mode-radio" type="radio" name="stonetop-roll-mode" value="adv" {{#if (eq stonetop.rollMode "adv")}}checked{{/if}}>
						<span class="steading-box" aria-hidden="true"></span>
						<span class="steading-option-text"><span>{{localize "stonetop.rollMode.adv"}}</span></span>
					</label>
					<label class="steading-rating-option">
						<input class="steading-box-input steading-roll-mode-radio" type="radio" name="stonetop-roll-mode" value="dis" {{#if (eq stonetop.rollMode "dis")}}checked{{/if}}>
						<span class="steading-box" aria-hidden="true"></span>
						<span class="steading-option-text"><span>{{localize "stonetop.rollMode.dis"}}</span></span>
					</label>
				</div>
			</div>

		</section>
	</header>

	{{!-- Tab navigation --}}
	{{!-- data-action="tab" is core ApplicationV2's built-in action (→ changeTab); each anchor
	      carries data-group because changeTab addresses `.tabs [data-group][data-tab]` directly. --}}
	<nav class="sheet-tabs tabs" data-group="primary">
		<a class="item {{tabs.overview.cssClass}}" data-action="tab" data-group="primary" data-tab="overview">Overview</a>
		<a class="item {{tabs.residents.cssClass}}" data-action="tab" data-group="primary" data-tab="residents">Residents</a>
		<a class="item {{tabs.neighbors.cssClass}}" data-action="tab" data-group="primary" data-tab="neighbors">Neighbors</a>
		<a class="item {{tabs.improvements.cssClass}}" data-action="tab" data-group="primary" data-tab="improvements">Improvements</a>
		<a class="item {{tabs.moves.cssClass}}" data-action="tab" data-group="primary" data-tab="moves">Moves</a>
		<a class="item {{tabs.notes.cssClass}}" data-action="tab" data-group="primary" data-tab="notes">Notes</a>
	</nav>

	<section class="sheet-body">

		{{!-- Overview tab --}}
		<div class="tab {{tabs.overview.cssClass}}" data-group="primary" data-tab="overview">

			<div class="steading-overview-grid">

				<section class="steading-overview-column">
					{{> "stonetop.steading-ratings-list" title="Resources" attr="prosperity" items=stonetop.attributes.prosperity.items}}
				</section>

				<div class="steading-overview-divider" aria-hidden="true"></div>

				<section class="steading-overview-column">
					{{> "stonetop.steading-ratings-list" title="Defenses" attr="defenses" items=stonetop.attributes.defenses.items}}
				</section>

				<div class="steading-overview-divider" aria-hidden="true"></div>

				<section class="steading-overview-column steading-assets-column">
					{{> "stonetop.steading-assets" items=stonetop.assets.items coinage=stonetop.assets.coinage}}
				</section>

			</div>

		</div>{{!-- /tab overview --}}

		{{!-- Residents tab --}}
		<div class="tab {{tabs.residents.cssClass}}" data-group="primary" data-tab="residents">

			<div class="steading-residents-grid">

				<section class="steading-residents-roster steading-panel-frame">
					<span class="panel-corner panel-corner-tl"></span>
					<span class="panel-corner panel-corner-tr"></span>
					<span class="panel-corner panel-corner-bl"></span>
					<span class="panel-corner panel-corner-br"></span>
					<span class="panel-edge panel-edge-top"></span>
					<span class="panel-edge panel-edge-right"></span>
					<span class="panel-edge panel-edge-bottom"></span>
					<span class="panel-edge panel-edge-left"></span>

					<div class="steading-residents-table">
						<div class="steading-residents-header">
							<span>Name (Pronouns)</span>
							<span>Occupation</span>
							<span>Traits, Relations, Etc</span>
						</div>
						<div class="steading-residents-rows">
							{{#each stonetop.residents}}
								<div class="steading-resident-row">
									<input type="text" class="stonetop-resident-name" data-id="{{id}}" value="{{name}}" placeholder="Name (Pronouns)">
									<input type="text" class="stonetop-resident-occupation" data-id="{{id}}" value="{{occupation}}" placeholder="Occupation">
									<input type="text" class="stonetop-resident-traits" data-id="{{id}}" value="{{traits}}" placeholder="Traits, Relations, Etc">
									<button class="stonetop-resident-remove stonetop-icon-btn" type="button" data-id="{{id}}" data-name="{{name}}" title="Delete resident" aria-label="Delete resident">
										<img src="systems/stonetop/assets/ui/controls/delete-icon.png" alt="">
									</button>
								</div>
							{{/each}}
						</div>
						<button class="stonetop-resident-add stonetop-icon-btn" type="button" title="Add resident" aria-label="Add resident">
							<img src="systems/stonetop/assets/ui/controls/plus-icon.png" alt="">
						</button>
					</div>
				</section>

				<div class="steading-residents-divider" aria-hidden="true"></div>

				<section class="steading-resident-names steading-panel-frame">
					<span class="panel-corner panel-corner-tl"></span>
					<span class="panel-corner panel-corner-tr"></span>
					<span class="panel-corner panel-corner-bl"></span>
					<span class="panel-corner panel-corner-br"></span>
					<span class="panel-edge panel-edge-top"></span>
					<span class="panel-edge panel-edge-right"></span>
					<span class="panel-edge panel-edge-bottom"></span>
					<span class="panel-edge panel-edge-left"></span>
					<h2>Names</h2>
					<p class="steading-names-text">{{stonetop.residentNames}}</p>
					<img class="steading-residents-img" src="stonetop-art/steading/residents.png" alt="">
				</section>

			</div>

			<section class="steading-npc-traits steading-panel-frame">
				<span class="panel-corner panel-corner-tl"></span>
				<span class="panel-corner panel-corner-tr"></span>
				<span class="panel-corner panel-corner-bl"></span>
				<span class="panel-corner panel-corner-br"></span>
				<span class="panel-edge panel-edge-top"></span>
				<span class="panel-edge panel-edge-right"></span>
				<span class="panel-edge panel-edge-bottom"></span>
				<span class="panel-edge panel-edge-left"></span>

				<div class="steading-npc-traits-heading">
					<h2>NPC Traits</h2>
					<span>Assign as needed; choose from this list or make up your own.</span>
				</div>
				<textarea class="steading-npc-traits-source">{{stonetop.residentTraitsText}}</textarea>
				<div class="steading-npc-traits-columns">
					{{#each stonetop.npcTraitColumns}}
						<div class="steading-npc-traits-column">
							{{#each this}}
								<div class="steading-npc-trait">{{this}}</div>
							{{/each}}
						</div>
					{{/each}}
				</div>
			</section>

		</div>{{!-- /tab residents --}}

		{{!-- Neighbors tab --}}
		<div class="tab {{tabs.neighbors.cssClass}}" data-group="primary" data-tab="neighbors">

			<div class="steading-neighbors-grid">

				<section class="steading-neighbors-roster steading-panel-frame">
					<span class="panel-corner panel-corner-tl"></span>
					<span class="panel-corner panel-corner-tr"></span>
					<span class="panel-corner panel-corner-bl"></span>
					<span class="panel-corner panel-corner-br"></span>
					<span class="panel-edge panel-edge-top"></span>
					<span class="panel-edge panel-edge-right"></span>
					<span class="panel-edge panel-edge-bottom"></span>
					<span class="panel-edge panel-edge-left"></span>

					<div class="steading-residents-table steading-neighbors-table">
						<div class="steading-residents-header steading-neighbors-header">
							<span>Name (Pronouns)</span>
							<span>Occupation</span>
							<span>Traits, Relations, Etc</span>
							<span>Home</span>
						</div>
						<div class="steading-residents-rows">
							{{#each stonetop.neighbors.people}}
								<div class="steading-resident-row steading-neighbor-row">
									<input type="text" class="stonetop-neighbor-person-name" data-id="{{id}}" value="{{name}}" placeholder="Name (Pronouns)">
									<input type="text" class="stonetop-neighbor-person-occupation" data-id="{{id}}" value="{{occupation}}" placeholder="Occupation">
									<input type="text" class="stonetop-neighbor-person-traits" data-id="{{id}}" value="{{traits}}" placeholder="Traits, Relations, Etc">
									<input type="text" class="stonetop-neighbor-person-home" data-id="{{id}}" value="{{home}}" placeholder="Home">
									<button class="stonetop-neighbor-person-remove stonetop-icon-btn" type="button" data-id="{{id}}" data-name="{{name}}" title="Delete neighbor" aria-label="Delete neighbor">
										<img src="systems/stonetop/assets/ui/controls/delete-icon.png" alt="">
									</button>
								</div>
							{{/each}}
						</div>
						<button class="stonetop-neighbor-person-add stonetop-icon-btn" type="button" title="Add neighbor" aria-label="Add neighbor">
							<img src="systems/stonetop/assets/ui/controls/plus-icon.png" alt="">
						</button>
					</div>
				</section>

				<div class="steading-neighbors-divider" aria-hidden="true"></div>

				{{> "stonetop.steading-neighbor-places" places=stonetop.neighbors.places}}

			</div>

		</div>{{!-- /tab neighbors --}}

		{{!-- Improvements tab --}}
		<div class="tab {{tabs.improvements.cssClass}}" data-group="primary" data-tab="improvements">

			<div class="steading-improvements-grid">

				<section class="steading-improvement-column" data-column="left">
					{{#each stonetop.improvementColumns.left}}
						<div class="steading-improvement-group steading-panel-frame">
							<span class="panel-corner panel-corner-tl"></span>
							<span class="panel-corner panel-corner-tr"></span>
							<span class="panel-corner panel-corner-bl"></span>
							<span class="panel-corner panel-corner-br"></span>
							<span class="panel-edge panel-edge-top"></span>
							<span class="panel-edge panel-edge-right"></span>
							<span class="panel-edge panel-edge-bottom"></span>
							<span class="panel-edge panel-edge-left"></span>
							{{> "stonetop.improvement-group"}}
						</div>
					{{/each}}
				</section>

				<div class="steading-improvements-divider" aria-hidden="true"></div>

				<section class="steading-improvement-column" data-column="middle">
					{{#each stonetop.improvementColumns.middle}}
						<div class="steading-improvement-group steading-panel-frame">
							<span class="panel-corner panel-corner-tl"></span>
							<span class="panel-corner panel-corner-tr"></span>
							<span class="panel-corner panel-corner-bl"></span>
							<span class="panel-corner panel-corner-br"></span>
							<span class="panel-edge panel-edge-top"></span>
							<span class="panel-edge panel-edge-right"></span>
							<span class="panel-edge panel-edge-bottom"></span>
							<span class="panel-edge panel-edge-left"></span>
							{{> "stonetop.improvement-group"}}
						</div>
					{{/each}}
				</section>

				<div class="steading-improvements-divider" aria-hidden="true"></div>

				<section class="steading-improvement-column" data-column="right">
					{{#each stonetop.improvementColumns.right}}
						<div class="steading-improvement-group steading-panel-frame">
							<span class="panel-corner panel-corner-tl"></span>
							<span class="panel-corner panel-corner-tr"></span>
							<span class="panel-corner panel-corner-bl"></span>
							<span class="panel-corner panel-corner-br"></span>
							<span class="panel-edge panel-edge-top"></span>
							<span class="panel-edge panel-edge-right"></span>
							<span class="panel-edge panel-edge-bottom"></span>
							<span class="panel-edge panel-edge-left"></span>
							{{> "stonetop.improvement-group"}}
						</div>
					{{/each}}
				</section>

			</div>

		</div>{{!-- /tab improvements --}}

		{{!-- Moves tab --}}
		<div class="tab {{tabs.moves.cssClass}}" data-group="primary" data-tab="moves">
			<section class="sheet-tab">
				{{#if stonetop.moves}}
					{{!-- alwaysShowResource: homefront moves are the steading's fixed set, so their
					      resource pips show whether or not the move reads as "acquired". --}}
					{{> "stonetop.move-group"
					    title=stonetop.moves.label
					    note=stonetop.moves.note
					    moves=stonetop.moves.moves
					    categoryKey=stonetop.moves.key
					    allowAdditional=false
					    alwaysShowResource=true}}
				{{else}}
					<p class="stonetop-moves-empty">No homefront moves assigned to this steading.</p>
				{{/if}}
			</section>
		</div>{{!-- /tab moves --}}

		{{!-- Notes tab --}}
		<div class="tab {{tabs.notes.cssClass}}" data-group="primary" data-tab="notes">

			<div class="steading-notes-grid">

				<section class="steading-notes-column">
					{{> "stonetop.steading-places-of-interest" places=stonetop.placesOfInterest}}
				</section>

				<div class="steading-notes-divider" aria-hidden="true"></div>

				<section class="steading-notes-column steading-notes-content-column">
					{{#each stonetop.content}}
						<div class="steading-notes-field steading-notes-content-field steading-panel-frame">
							<span class="panel-corner panel-corner-tl"></span>
							<span class="panel-corner panel-corner-tr"></span>
							<span class="panel-corner panel-corner-bl"></span>
							<span class="panel-corner panel-corner-br"></span>
							<span class="panel-edge panel-edge-top"></span>
							<span class="panel-edge panel-edge-right"></span>
							<span class="panel-edge panel-edge-bottom"></span>
							<span class="panel-edge panel-edge-left"></span>
							<h2>{{rich label}}{{#if note.raw}} <small>{{rich note}}</small>{{/if}}</h2>
							<textarea class="stonetop-content-textarea" data-type="{{slug}}">{{text}}</textarea>
						</div>
					{{/each}}
				</section>

				<div class="steading-notes-divider" aria-hidden="true"></div>

				<section class="steading-notes-column">
					<div class="steading-notes-field steading-panel-frame">
						<span class="panel-corner panel-corner-tl"></span>
						<span class="panel-corner panel-corner-tr"></span>
						<span class="panel-corner panel-corner-bl"></span>
						<span class="panel-corner panel-corner-br"></span>
						<span class="panel-edge panel-edge-top"></span>
						<span class="panel-edge panel-edge-right"></span>
						<span class="panel-edge panel-edge-bottom"></span>
						<span class="panel-edge panel-edge-left"></span>
						<h2>Notes</h2>
						<textarea class="stonetop-notes">{{stonetop.notes}}</textarea>
					</div>
				</section>

			</div>

		</div>{{!-- /tab notes --}}

	</section>{{!-- /sheet-body --}}

</div>
