{
	"$schema": "https://json.schemastore.org/foundryvtt-system-manifest.json",
	"id": "stonetop",
	"title": "Stonetop",
	"description": "An unofficial system for playing Stonetop in Foundry VTT.",
	"version": "0.11.0",
	"compatibility": {
		"minimum": "13",
		"verified": "14"
	},
	"authors": [
		{
			"name": "aMediocerDad"
		},
		{
			"name": "taylor-nightingale"
		},
		{
			"name": "pervandyke"
		},
		{
			"name": "Dice-Goblin-Click-Clack"
		}
	],
	"flags": {
		"hotReload": {
			"extensions": ["css", "js", "hbs", "json"],
			"paths": [
				"stonetop.js",
				"module",
				"styles",
				"languages",
				"templates"
			]
		}
	},
	"esmodules": [
		"stonetop.js"
	],
	"styles": [
		"styles/stonetop.css"
	],
	"languages": [
		{
			"lang": "en",
			"name": "English",
			"path": "languages/en.json"
		}
	],
	"documentTypes": {
		"Actor": {
			"character": {},
			"npc":       {},
			"steading":  {}
		},
		"Item": {
			"move":        {},
			"arcanum":     {},
			"playbook":    {},
			"insert":      {},
			"improvement": {},
			"npc":         {},
			"outfitItem":  {},
			"possession":  {}
		}
	},
	"packs": [
		{
			"name": "moves",
			"label": "Moves",
			"path": "packs/moves",
			"type": "Item",
			"system": "stonetop"
		},
		{
			"name": "playbooks",
			"label": "Playbooks",
			"path": "packs/playbooks",
			"type": "Item",
			"system": "stonetop"
		},
		{
			"name": "outfit-items",
			"label": "Inventory Items",
			"path": "packs/outfit-items",
			"type": "Item",
			"system": "stonetop"
		},
		{
			"name": "arcana",
			"label": "Arcana",
			"path": "packs/arcana",
			"type": "Item",
			"system": "stonetop"
		},
		{
			"name": "inserts",
			"label": "Inserts",
			"path": "packs/inserts",
			"type": "Item",
			"system": "stonetop"
		},
		{
			"name": "followers",
			"label": "Followers",
			"path": "packs/followers",
			"type": "Item",
			"system": "stonetop"
		},
		{
			"name": "possessions",
			"label": "Possessions",
			"path": "packs/possessions",
			"type": "Item",
			"system": "stonetop"
		},
		{
			"name": "steading-improvements",
			"label": "Steading Improvements",
			"path": "packs/steading-improvements",
			"type": "Item",
			"system": "stonetop"
		}
	],
	"url": "https://github.com/taylor-nightingale/stonetop",
	"license": "LICENSE",
	"manifest": "https://github.com/taylor-nightingale/stonetop/releases/latest/download/system.json",
	"download": "https://github.com/taylor-nightingale/stonetop/archive/refs/heads/main.zip"
}
